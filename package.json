{
    "name": "reminder-gram",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build && npm run copy:assets",
        "copy:assets": "cpx \"src/infrastructure/external/llm/prompts/**/*\" dist/src/infrastructure/external/llm/prompts/",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "lint": "biome lint .",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.1",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/typeorm": "^11.0.0",
        "@telegraf/session": "^2.0.0-beta.7",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "google-auth-library": "^9.15.1",
        "googleapis": "^148.0.0",
        "morgan": "^1.10.0",
        "node-cron": "^4.0.6",
        "openai": "^4.100.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "sqlite3": "^5.1.7",
        "telegraf": "^4.16.3",
        "telegraf-session-local": "^2.1.1",
        "typeorm": "^0.3.24",
        "zod": "^3.24.4"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@swc/cli": "^0.6.0",
        "@swc/core": "^1.10.7",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.7",
        "@types/supertest": "^6.0.2",
        "cpx": "^1.5.0",
        "eslint": "^9.27.0",
        "jest": "^29.7.0",
        "prettier": "^3.5.3",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
